PORT=5000
NODE_ENV=production
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/pizza-app
JWT_SECRET=replace-with-a-long-random-secret
ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app

# Razorpay live setup:
# 1. Activate Razorpay account/KYC in Razorpay Dashboard.
# 2. Switch Dashboard to Live Mode.
# 3. Generate live API keys and paste them below.
RAZORPAY_MODE=live
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
