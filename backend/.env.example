# ============================================================
# Pizza Customization Web App — Backend Environment Variables
# ============================================================
# Copy this file to backend/.env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Create a free cluster at https://cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/pizza-app

# JWT signing secret — use a long random string (32+ characters)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Additional signing/encryption key
SECRET_KEY=replace_with_another_long_random_secret

# Comma-separated list of allowed CORS origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000

# Razorpay payment gateway credentials
# Get these from your Razorpay dashboard: https://dashboard.razorpay.com
# ⚠️  ROTATE IMMEDIATELY if previously committed — these allow refunds and order creation
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_razorpay_key_secret

# Optional: force Razorpay mode. Defaults to "auto" (detected from key prefix).
# Values: "auto" | "test" | "live"
# RAZORPAY_MODE=auto
